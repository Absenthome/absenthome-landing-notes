# YouTube API Configuration (Build-time only)
# Videos are fetched during build/start and pre-rendered
# API key is NEVER exposed to users in the browser

# Get your API key from: https://console.cloud.google.com/apis/credentials
# Make sure YouTube Data API v3 is enabled
# This key is only needed when running `yarn start` or `yarn build`

DOCUSAURUS_YOUTUBE_API_KEY=your_api_key_here
